# Copy to frontend/.env.production (do not commit)

NODE_ENV=production
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
TELEGRAM_BOT_USERNAME=my_tracker_bot
REDIS_URL=redis://redis:6379

# ─── Sentry (опционально) ─────────────────────────────────────
# DSN из Sentry → Settings → Projects → tracker-frontend → Client Keys
SENTRY_DSN=
# Для браузера (можно тот же DSN). В Docker — передать на этапе build (см. docs/SENTRY.md)
NEXT_PUBLIC_SENTRY_DSN=
# Для загрузки source maps при CI/CD (не обязательно для старта)
# SENTRY_ORG=
# SENTRY_PROJECT=tracker-frontend
# SENTRY_AUTH_TOKEN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
