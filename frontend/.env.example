# Скопируйте в `.env.local` (не коммитьте `.env.local`)

# ─── Supabase ──────────────────────────────────────────────
# Project URL — только хост, без /rest/v1
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# next.config.ts пробрасывает их в NEXT_PUBLIC_* для браузера и middleware.
# SERVICE_ROLE_KEY — только для серверных скриптов, не для фронтенда:
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Telegram integration ──────────────────────────────────
# Username бота без @ (например: my_tracker_bot). Используется для генерации deep-link.
TELEGRAM_BOT_USERNAME=

# Публичный URL бота для health-проверок и админ-операций (опционально).
# NEXT_PUBLIC_TELEGRAM_BOT_URL=https://bot.example.com

# Общий секрет для server-to-server вызовов между frontend и bot (если потребуется).
# INTERNAL_API_KEY=

# ─── Auth rate limit (API /api/auth/*) ─────────────────────────────────────
# Без REDIS_URL — in-memory (на инстанс). С REDIS_URL — общий счётчик (как у bot).
# REDIS_URL=redis://localhost:6379
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_SIGN_IN_MAX_PER_IP=10
# AUTH_SIGN_IN_MAX_PER_EMAIL=5
# AUTH_SIGN_UP_MAX_PER_IP=5
