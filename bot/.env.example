# Скопируйте в `bot/.env` (не коммитьте `.env`)

# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
# Уровень логов: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Telegram ─────────────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# Username бота без @ (используется для генерации deep-link во фронте — здесь только для логов)
TELEGRAM_BOT_USERNAME=
# Режим: polling (dev) | webhook (prod)
TELEGRAM_MODE=polling

# Только для TELEGRAM_MODE=webhook:
# Публичный HTTPS-URL бота (без trailing slash). Telegram будет слать обновления на /tg/webhook/<secret>.
TELEGRAM_WEBHOOK_BASE_URL=
# Случайный секрет для пути webhook (>= 16 символов). Включается в URL, чтобы скрыть endpoint.
TELEGRAM_WEBHOOK_PATH_SECRET=
# Заголовок X-Telegram-Bot-Api-Secret-Token (Telegram отправляет вместе с каждым update).
TELEGRAM_WEBHOOK_HEADER_SECRET=
# Порт HTTP-сервера для webhook + healthcheck
HTTP_PORT=3001
HTTP_HOST=0.0.0.0
# Порт health/metrics для worker-процесса
WORKER_HTTP_PORT=3002

# ─── Supabase ─────────────────────────────────────────────────
# То же значение, что и SUPABASE_URL во frontend/.env
SUPABASE_URL=https://xxxx.supabase.co
# ⚠️ SERVICE_ROLE key — обходит RLS. Только для бота, никогда не клиенту!
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis (BullMQ) ───────────────────────────────────────────
# Для локального dev: redis://localhost:6379
# Для Upstash/Redis Cloud: rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379
# Префикс ключей BullMQ (полезно при шаринге одного Redis между средами)
BULLMQ_PREFIX=tracker

# ─── Defaults ─────────────────────────────────────────────────
# Тайм-зона по умолчанию для новых связок
DEFAULT_TIMEZONE=Europe/Moscow
# Язык по умолчанию для интерфейса бота
DEFAULT_LOCALE=ru

# ─── Sentry (опционально) ─────────────────────────────────────
# DSN из Sentry → Settings → Projects → tracker-bot → Client Keys
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
