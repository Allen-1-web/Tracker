# Base URL for Playwright to hit
# Dedicated port avoids clashing with local `npm run dev` (3000/3010).
E2E_BASE_URL=http://127.0.0.1:3099

# Supabase (TEST project!) service role for cleanup
E2E_SUPABASE_URL=
E2E_SUPABASE_SERVICE_ROLE_KEY=

# Optional: if you want tests to login existing user in future
E2E_EXISTING_USER_EMAIL=
E2E_EXISTING_USER_PASSWORD=

